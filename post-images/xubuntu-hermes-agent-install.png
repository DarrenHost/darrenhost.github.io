<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="675" viewBox="0 0 1200 675">
  <!-- Background -->
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#E95420"/>
      <stop offset="100%" style="stop-color:#772953"/>
    </linearGradient>
    <linearGradient id="screen" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#2D2D2D"/>
      <stop offset="100%" style="stop-color:#1A1A1A"/>
    </linearGradient>
  </defs>
  
  <rect width="1200" height="675" fill="url(#bg)"/>
  
  <!-- Terminal Window -->
  <rect x="150" y="150" width="900" height="400" rx="10" fill="url(#screen)" stroke="#333" stroke-width="2"/>
  
  <!-- Terminal Header -->
  <rect x="150" y="150" width="900" height="40" rx="10" fill="#3D3D3D"/>
  <circle cx="180" cy="170" r="8" fill="#E95420"/>
  <circle cx="210" cy="170" r="8" fill="#5E5E5E"/>
  <circle cx="240" cy="170" r="8" fill="#5E5E5E"/>
  <text x="300" y="175" fill="#999" font-family="monospace" font-size="14">user@xubuntu:~</text>
  
  <!-- Terminal Content -->
  <text x="180" y="230" fill="#4E9A06" font-family="monospace" font-size="16">user@xubuntu:~$ <tspan fill="#FFFFFF">git clone https://github.com/anthropics/hermes.git</tspan></text>
  <text x="180" y="270" fill="#4E9A06" font-family="monospace" font-size="16">user@xubuntu:~$ <tspan fill="#FFFFFF">cd hermes</tspan></text>
  <text x="180" y="310" fill="#4E9A06" font-family="monospace" font-size="16">user@xubuntu:~/hermes$ <tspan fill="#FFFFFF">pip install -e .</tspan></text>
  <text x="180" y="350" fill="#4E9A06" font-family="monospace" font-size="16">user@xubuntu:~/hermes$ <tspan fill="#FFFFFF">hermes --version</tspan></text>
  <text x="180" y="410" fill="#FFFFFF" font-family="monospace" font-size="18">Hermes Agent v1.0.0 ✨</text>
  <text x="180" y="450" fill="#888" font-family="monospace" font-size="14">AI Agent for task automation</text>
  
  <!-- AI Icon -->
  <circle cx="950" cy="350" r="80" fill="none" stroke="#FFFFFF" stroke-width="3" opacity="0.3"/>
  <circle cx="950" cy="350" r="50" fill="none" stroke="#FFFFFF" stroke-width="3" opacity="0.5"/>
  <circle cx="950" cy="350" r="20" fill="#FFFFFF" opacity="0.7"/>
  
  <!-- Title Text -->
  <text x="600" y="80" text-anchor="middle" fill="#FFFFFF" font-family="Arial, sans-serif" font-size="36" font-weight="bold">Xubuntu 系统安装</text>
  <text x="600" y="125" text-anchor="middle" fill="#FFFFFF" font-family="Arial, sans-serif" font-size="36" font-weight="bold">Hermes Agent 快速指南</text>
  
  <!-- Ubuntu Logo Elements -->
  <circle cx="100" cy="600" r="30" fill="#E95420" opacity="0.5"/>
  <circle cx="1100" cy="75" r="25" fill="#E95420" opacity="0.5"/>
  
  <!-- Code decoration -->
  <text x="1000" y="550" fill="#FFFFFF" font-family="monospace" font-size="12" opacity="0.3">
    <tspan x="1000" dy="0">#!/bin/bash</tspan>
    <tspan x="1000" dy="20">sudo apt install python3-pip</tspan>
    <tspan x="1000" dy="20">pip install hermes-agent</tspan>
  </text>
</svg>
